@{
    var title = ViewData["Title"] ?? "IxnayServer";
}
<!doctype html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>@title</title>
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <header>
        <nav>
            <a href="/">Home</a> |
            <a href="/Games">Games</a>
        </nav>
    </header>
    <main role="main">
        @RenderBody()
    </main>
    <footer>
        <small>&copy; @DateTime.UtcNow.Year IxnayServer</small>
    </footer>
</body>
</html>